# ==========================================================
# Basirhat College Updates Bot - Environment Configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file to version control.
# ==========================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=123456789:AAExampleTokenReplaceWithReal

# Comma separated Telegram numeric user IDs allowed to use the Admin Panel
# Example: 111111111,222222222
ADMIN_IDS=111111111

# Public username of the bot (without @) - used in messages/links
BOT_USERNAME=basirhatcollege_updates_bot

# HTTP server port (used for health checks / webhook endpoint)
PORT=3000

# Bot mode: "polling" or "webhook"
BOT_MODE=polling

# Required only when BOT_MODE=webhook
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/telegram/webhook

# Database driver: "sqlite" (default) or "mysql"
DATABASE=sqlite

# SQLite database file path (used when DATABASE=sqlite)
SQLITE_PATH=./database/bot.db

# MySQL configuration (used only when DATABASE=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=basirhat_bot

# Application environment: development | production
NODE_ENV=production

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info

# College Information
COLLEGE_NAME=Basirhat College
COLLEGE_WEBSITE=https://basirhatcollege.ac.in
COLLEGE_CONTACT_PHONE=+91-0000000000
COLLEGE_CONTACT_EMAIL=info@basirhatcollege.ac.in
COLLEGE_ADDRESS=Basirhat, North 24 Parganas, West Bengal, India

# Rate limiting (per user, per command window)
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX_REQUESTS=8

# Broadcast throttling (messages per second to avoid Telegram flood limits)
BROADCAST_MESSAGES_PER_SECOND=25

# Automatic database backup interval in hours
BACKUP_INTERVAL_HOURS=24

# Maximum upload file size in MB (Telegram bot API hard limit is 50MB via Bot API upload, 20MB download without local API server)
MAX_FILE_SIZE_MB=20
