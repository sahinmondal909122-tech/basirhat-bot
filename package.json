{
  "name": "basirhatcollege-updates-bot",
  "version": "1.0.0",
  "description": "Production-ready Telegram Bot for Basirhat College Updates (@basirhatcollege_updates_bot)",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src --ext .js",
    "backup": "node src/utils/manualBackup.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs basirhatcollege-updates-bot"
  },
  "keywords": [
    "telegram-bot",
    "basirhat-college",
    "nodejs",
    "express",
    "sqlite"
  ],
  "author": "Basirhat College Tech Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "winston": "^3.13.1",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
